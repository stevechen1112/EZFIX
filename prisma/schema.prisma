// Prisma schema for 恆惠紗窗網站
// 本機開發使用 SQLite；上線至 Linode 時把 provider 改為 "postgresql"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- 後台帳號 ----------
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt 雜湊
  name      String   @default("管理員")
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Hero 輪播 ----------
model HeroSlide {
  id        Int      @id @default(autoincrement())
  image     String   // /uploads/xxx.jpg
  title     String
  subtitle  String   @default("")
  ctaLabel  String   @default("立即諮詢")
  ctaHref   String   @default("tel:0938989579")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- 服務項目 ----------
model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  features    String   @default("[]") // JSON 字串：["項目1","項目2"]
  icon        String   @default("wrench") // icon 名稱（lucide）
  image       String   @default("")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- 客戶評論 ----------
model Review {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  rating    Int      @default(5)
  avatar    String   @default("")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- 服務區域 ----------
model ServiceArea {
  id        Int      @id @default(autoincrement())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ---------- 網站設定（單筆） ----------
model SiteSettings {
  id            Int     @id @default(1)
  companyName   String  @default("恆惠修理紗窗")
  phone         String  @default("0938989579")
  lineUrl       String  @default("https://line.me/ti/p/_8YeYUnzjS")
  address       String  @default("台中市南區柳川東路一段50號")
  businessHours String  @default("08:00 AM - 17:00 PM")
  facebookUrl   String  @default("")
  instagramUrl  String  @default("")
  seoTitle      String  @default("恆惠修理紗窗｜台中專業紗窗維修訂製")
  seoDesc       String  @default("台中在地專業紗窗修理、折疊式紗窗訂製、鋁門窗維修、防霾網安裝服務。預約準時到場、價格透明。")
  ogImage       String  @default("")

  // Hero
  heroBadge     String  @default("台中專業紗窗修理")
  heroSubtitle  String  @default("紗窗維修訂製｜折疊式紗窗｜鋁門窗維修｜防霾網安裝")

  // 區塊標題與文案（後台可改）
  servicesTitle    String  @default("服務項目")
  areaTitle        String  @default("服務區域")
  areaMapImage     String  @default("/uploads/og/og-default.jpg")
  areaCtaLabel     String  @default("來電諮詢")
  reviewsTitle     String  @default("客戶回饋")
  reviewsSubtitle  String  @default("看看客戶對我們最新真實回饋")
  contactTitle     String  @default("聯絡我們")
  contactPhoneLabel String @default("電話")
  contactCtaLabel  String  @default("立即撥打")
  contactDescription String @default("依照您的現況提供最好的建議及最妥善的處理方式，協助您解決問題。")

  // 浮動 CTA 與手機底部按鈕
  floatingPhoneLabel String @default("來電諮詢")
  floatingLineLabel  String @default("LINE 諮詢")
  mobilePhoneLabel   String @default("立即聯絡")
  mobileLineLabel    String @default("Line")

  // Footer
  footerFbLabel      String @default("Facebook")
  footerLineLabel    String @default("LINE")
  footerCopyright    String @default("")

  // 第三方文章 API
  apiBaseUrl     String @default("") // 留空則使用 NEXT_PUBLIC_SITE_URL/api/v1
  apiKey         String @default("") // Bearer token
  apiPublishMode String @default("draft") // draft | published

  updatedAt     DateTime @updatedAt
}

// ---------- 媒體檔案 ----------
model Media {
  id        Int      @id @default(autoincrement())
  filename  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

// ---------- 部落格文章（專業分享） ----------
model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String    @default("")
  content     String
  contentFormat String  @default("plain") // plain | markdown
  coverImage  String    @default("")
  authorName  String    @default("恆惠修理紗窗")
  category    String    @default("") // 例：維修建議、案例分享、常見問題
  tags        String    @default("") // 逗號分隔
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ContentFlow 擴充欄位
  metaTitle       String? // SEO Title
  metaDescription String? // SEO Description
  jsonLd          String? // JSON-LD Schema（Article / FAQPage / HowTo）
}
