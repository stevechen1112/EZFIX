# ===== Database =====
# 本機開發用 SQLite
DATABASE_URL="file:./dev.db"

# 上線（Linode）改用 PostgreSQL 時，把這行打開並填入
# DATABASE_URL="postgresql://user:password@localhost:5432/henghui?schema=public"

# ===== Auth =====
# JWT 簽章用，請用 openssl rand -base64 32 產出
AUTH_SECRET="change-me-to-a-32-byte-random-string"

# ===== Site =====
NEXT_PUBLIC_SITE_URL="https://ezfix.com.tw"

# ===== Google Analytics 4 =====
# 在 GA4 後台：管理 → 資料串流 → 選 ezfix.com.tw → 衡量 ID（G-XXXXXXXXXX）
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ===== ContentFlow =====
# openssl rand -base64 32
CONTENTFLOW_SECRET=""
